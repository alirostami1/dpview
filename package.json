{
  "name": "dpview",
  "private": true,
  "scripts": {
    "bundle:web": "esbuild cmd/dpview/web/app.ts cmd/dpview/web/katex-runtime.ts cmd/dpview/web/katex-style.css --bundle --format=esm --platform=browser --target=es2022 --outdir=cmd/dpview/build-web --entry-names=[name] --loader:.css=css --loader:.woff=copy --loader:.woff2=copy --loader:.ttf=copy",
    "typecheck:web": "tsc --project tsconfig.json --noEmit",
    "build:web": "npm run typecheck:web && npm run bundle:web",
    "watch:web": "esbuild cmd/dpview/web/app.ts cmd/dpview/web/katex-runtime.ts cmd/dpview/web/katex-style.css --bundle --format=esm --platform=browser --target=es2022 --outdir=cmd/dpview/build-web --entry-names=[name] --loader:.css=css --loader:.woff=copy --loader:.woff2=copy --loader:.ttf=copy --watch"
  },
  "dependencies": {
    "katex": "^0.16.44",
    "morphdom": "^2.7.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2",
    "typescript-language-server": "^5.1.3"
  }
}
